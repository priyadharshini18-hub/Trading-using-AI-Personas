# OpenAI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here

# Polygon.io API Key for market data (required)
POLYGON_API_KEY=your_polygon_api_key_here

# Polygon plan: "free" (end-of-day), "paid" (15-min delay), "realtime"
POLYGON_PLAN=free

# Brave Search API Key for researcher agent web search
BRAVE_API_KEY=your_brave_api_key_here

# Pushover for push notifications (optional)
PUSHOVER_USER=your_pushover_user_key
PUSHOVER_TOKEN=your_pushover_app_token

# Alternative model providers (optional - only needed if USE_MANY_MODELS=true)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Trading scheduler settings
RUN_EVERY_N_MINUTES=60
RUN_EVEN_WHEN_MARKET_IS_CLOSED=false
USE_MANY_MODELS=false
